# Klientvariabler for Vite/React. Disse kan eksponeres i nettleseren.
# Uten Supabase-verdier starter appen i lokal testmodus.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-public-key
VITE_ENABLE_AUTH=true
VITE_DISABLE_GOOGLE_AUTH=false

# Frivillig: Google Calendar read-only import i familiekalenderen.
# Bruk OAuth Client ID for webapp. Ikke legg client secret i frontend.
VITE_GOOGLE_CALENDAR_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
VITE_GOOGLE_CALENDAR_DAYS_AHEAD=90

# Supabase Edge Function-secrets settes i Supabase, ikke som VITE_-variabler.
# Brukes av supabase/functions/send-family-invite.
SMTP_HOST=mail.notools.no
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=travelvault@notools.no
SMTP_PASS=your-email-password
SMTP_FROM=Travelvault <noreply@notools.no>
INVITE_FROM_EMAIL=noreply@notools.no
PUBLIC_APP_URL=https://travelvault.notools.no

# Brukes av supabase/functions/search-location for kart-/stedsøk.
NOMINATIM_CONTACT_EMAIL=travelvault@notools.no
